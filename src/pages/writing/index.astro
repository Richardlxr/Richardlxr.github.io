---
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPosts } from "../../data/posts";

const posts = await getPosts();
---

<BaseLayout title="Writing" description="Richard_L 的文章与学习笔记。">
  <section class="page-hero">
    <p class="eyebrow">@Richardlxr · Writing</p>
    <h1>文章与笔记</h1>
    <p>这里会慢慢记录学习、项目和生活。先从一声简单的招呼开始。</p>
  </section>

  <section class="content-section page-section" aria-label="文章列表">
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
