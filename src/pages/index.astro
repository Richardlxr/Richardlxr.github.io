---
import {
  Activity,
  ArrowRight,
  BookOpen,
  Code2,
  GitBranch,
  GraduationCap,
  MapPin,
  Sparkles,
  Zap
} from "@lucide/astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { posts } from "../data/posts";
import { projects } from "../data/projects";

const featuredPosts = posts.slice(0, 3);
const featuredProjects = projects.slice(0, 3);
---

<BaseLayout
  title="Richard_L — 个人博客"
  description="Richard_L 的个人博客，记录 C++、数据结构、AI Agent 工具链和项目折腾。"
>
  <section class="hero-section" aria-labelledby="hero-title">
    <span class="hero-ghost" aria-hidden="true">Notes</span>
    <div class="hero-copy">
      <p class="eyebrow">@Richardlxr · GitHub Pages</p>
      <h1 id="hero-title">你好，我是 Richard_L</h1>
      <p class="hero-lede">
        这里记录 C++、数据结构、AI Agent 工作流，以及把灵感做成可运行项目的过程。
      </p>
      <div class="tag-list">
        <span>C++</span>
        <span>数据结构</span>
        <span>AI Agent</span>
        <span>工具折腾</span>
        <span>学习笔记</span>
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href="https://github.com/Richardlxr" target="_blank" rel="noreferrer">
          <GitBranch size={18} strokeWidth={2.2} aria-hidden="true" />
          GitHub
        </a>
        <a class="button" href="/writing/">
          <BookOpen size={18} strokeWidth={2.2} aria-hidden="true" />
          最近文章
        </a>
      </div>
    </div>

    <figure class="hero-avatar">
      <div class="avatar-frame animated-avatar">
        <span class="avatar-orbit avatar-orbit-one" aria-hidden="true"></span>
        <span class="avatar-orbit avatar-orbit-two" aria-hidden="true"></span>
        <span class="avatar-bolt avatar-bolt-one" aria-hidden="true"></span>
        <span class="avatar-bolt avatar-bolt-two" aria-hidden="true"></span>
        <span class="avatar-blossom avatar-blossom-one" aria-hidden="true"></span>
        <span class="avatar-blossom avatar-blossom-two" aria-hidden="true"></span>
        <div class="avatar-image-shell">
          <img src="/images/profile-avatar.webp" alt="个人博客头像" width="480" height="480" loading="eager" />
        </div>
      </div>
      <figcaption>
        <Sparkles size={16} strokeWidth={2.2} aria-hidden="true" />
        Richard_L
      </figcaption>
    </figure>
  </section>

  <div class="home-grid">
    <div class="home-main">
      <section class="content-section" aria-labelledby="recent-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Writing</p>
            <h2 id="recent-title">最近文章</h2>
          </div>
          <a class="text-link" href="/writing/">
            全部文章
            <ArrowRight size={16} strokeWidth={2.2} aria-hidden="true" />
          </a>
        </div>
        <div class="post-list">
          {featuredPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>

      <section class="content-section" aria-labelledby="project-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Projects</p>
            <h2 id="project-title">正在打磨的项目</h2>
          </div>
          <a class="text-link" href="/projects/">
            项目页
            <ArrowRight size={16} strokeWidth={2.2} aria-hidden="true" />
          </a>
        </div>
        <div class="project-grid">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>

      <section class="content-section learning-section" aria-labelledby="learning-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Learning</p>
            <h2 id="learning-title">学习轨迹</h2>
          </div>
        </div>
        <div class="learning-map" role="list">
          <div role="listitem">
            <span><Code2 size={18} strokeWidth={2.2} aria-hidden="true" /></span>
            <strong>C++ 基础</strong>
            <p>语法、STL、模板和工程化写法持续补齐。</p>
          </div>
          <div role="listitem">
            <span><GraduationCap size={18} strokeWidth={2.2} aria-hidden="true" /></span>
            <strong>数据结构</strong>
            <p>用题解和模板把抽象概念沉淀成可复用经验。</p>
          </div>
          <div role="listitem">
            <span><Zap size={18} strokeWidth={2.2} aria-hidden="true" /></span>
            <strong>Agent 工作流</strong>
            <p>把开发、复盘和文档沉淀连接成稳定循环。</p>
          </div>
        </div>
      </section>
    </div>

    <aside class="side-rail" aria-label="站点状态">
      <section class="widget status-widget">
        <p class="widget-title">
          <Activity size={16} strokeWidth={2.2} aria-hidden="true" />
          在线 / Active
        </p>
        <ul class="status-list">
          <li>
            <MapPin size={16} strokeWidth={2.2} aria-hidden="true" />
            Shanghai
          </li>
          <li>
            <Sparkles size={16} strokeWidth={2.2} aria-hidden="true" />
            整理技术笔记中...
          </li>
          <li>
            <Zap size={16} strokeWidth={2.2} aria-hidden="true" />
            ovo
          </li>
        </ul>
      </section>

      <section class="widget focus-widget">
        <p class="widget-title">本周焦点</p>
        <div class="focus-meter">
          <div class="focus-item" style="--value: 72%">
            <span>C++ / STL</span>
            <strong>72%</strong>
          </div>
          <div class="focus-item" style="--value: 58%">
            <span>数据结构</span>
            <strong>58%</strong>
          </div>
          <div class="focus-item" style="--value: 64%">
            <span>Agent</span>
            <strong>64%</strong>
          </div>
        </div>
      </section>

      <section class="widget quote-widget">
        <p class="widget-title">今日札记</p>
        <blockquote>
          先让想法跑起来，再把跑过的路整理成地图。
        </blockquote>
      </section>
    </aside>
  </div>
</BaseLayout>
