---
import { ArrowRight, BookOpen } from "@lucide/astro";
import type { Post } from "../data/posts";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const date = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(new Date(post.date));
---

<article class="post-card">
  <a class="post-card-link" href={post.href} aria-label={`阅读：${post.title}`}>
    <span class="post-icon" aria-hidden="true">
      <BookOpen size={20} stroke-width={2.1} />
    </span>
    <span class="post-content">
      <span class="post-row">
        <strong>{post.title}</strong>
        <span class="reading-time">{post.readingTime}</span>
      </span>
      <span class="post-excerpt">{post.excerpt}</span>
      <span class="post-meta">
        <time datetime={post.date}>{date}</time>
        {post.tags.map((tag) => <span>{tag}</span>)}
      </span>
    </span>
    <ArrowRight class="post-arrow" size={18} stroke-width={2.2} aria-hidden="true" />
  </a>
</article>
