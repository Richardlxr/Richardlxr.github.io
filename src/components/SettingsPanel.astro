---
import { Monitor, Moon, Settings, Sun } from "@lucide/astro";
---

<div class="settings-dock">
  <button class="icon-button" type="button" aria-label="站点设置" aria-expanded="false" data-settings-toggle>
    <Settings size={18} stroke-width={2.2} aria-hidden="true" />
  </button>
  <div class="settings-panel" data-settings-panel hidden>
    <p class="settings-title">站点设置</p>
    <div class="settings-row">
      <span>主题</span>
      <div class="segmented-control" role="group" aria-label="主题">
        <button type="button" aria-label="跟随系统" title="跟随系统" data-theme-choice="system">
          <Monitor size={16} stroke-width={2.2} aria-hidden="true" />
        </button>
        <button type="button" aria-label="浅色" title="浅色" data-theme-choice="light">
          <Sun size={16} stroke-width={2.2} aria-hidden="true" />
        </button>
        <button type="button" aria-label="深色" title="深色" data-theme-choice="dark">
          <Moon size={16} stroke-width={2.2} aria-hidden="true" />
        </button>
      </div>
    </div>
    <label class="range-control">
      <span>花瓣数量</span>
      <input type="range" min="0" max="18" value="12" data-petal-count />
    </label>
  </div>
</div>
